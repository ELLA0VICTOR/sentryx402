PORT=4021
PUBLIC_APP_ORIGIN=http://localhost:4021

STELLAR_NETWORK=stellar:testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

X402_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
X402_FACILITATOR_API_KEY=

STELLAR_PAY_TO=
X402_SEARCH_PRICE=$0.01
X402_NEWS_PRICE=$0.02

# Optional: use Tavily as the primary production-safe search provider
TAVILY_API_KEY=

# Optional: use Brave Search as a secondary search provider
BRAVE_SEARCH_API_KEY=

POLICY_MAX_USD_PER_REQUEST=0.05
POLICY_DAILY_USD_CAP=1.0

# Optional: comma separated list when serving the API on a different origin
# CORS_ORIGIN=http://localhost:5173

# Frontend-only on Vercel:
# VITE_API_BASE_URL=https://your-backend-name.onrender.com
